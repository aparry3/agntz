{
  "version": 1,
  "grantSemantics": {
    "grant": "app/user/u_123",
    "readableScopes": ["app", "app/user", "app/user/u_123"],
    "defaultWritableScopes": ["app/user/u_123", "app/user/u_123/*"],
    "notReadableScopes": ["app/user/u_456"],
    "notWritableScopes": ["app/user", "app/user/u_456"]
  },
  "resourceConfig": {
    "manifest": {
      "resources": {
        "memory": {
          "kind": "memory",
          "mode": "read-write",
          "autoScan": true,
          "writePolicy": {
            "descendants": true,
            "ancestorPromotion": "none"
          }
        }
      }
    },
    "reservedToolNames": ["memory_read", "memory_write"]
  },
  "writeFlow": [
    "agent calls memory_write with content",
    "memrez reasoner selects a namespace from the run grants and write policy",
    "memrez validates the selected namespace before persisting",
    "memrez stores normalized content, topics, type, source, and timestamps"
  ],
  "scenarios": [
    {
      "name": "ancestor-read-without-sibling-leakage",
      "writes": [
        {
          "grants": ["app"],
          "content": "Global policy.",
          "topicsHint": ["shared"]
        },
        {
          "grants": ["app/user/u_123"],
          "content": "User 123 preference.",
          "topicsHint": ["prefs"]
        },
        {
          "grants": ["app/user/u_456"],
          "content": "User 456 preference.",
          "topicsHint": ["prefs"]
        }
      ],
      "reads": [
        {
          "grants": ["app/user/u_123"],
          "topic": "shared",
          "contents": ["Global policy."]
        },
        {
          "grants": ["app/user/u_123"],
          "topic": "prefs",
          "contents": ["User 123 preference."]
        }
      ],
      "scan": {
        "grants": ["app/user/u_123"],
        "topics": [
          ["prefs", 1],
          ["shared", 1]
        ]
      }
    },
    {
      "name": "write-sibling-rejected",
      "grants": ["app/user/u_123"],
      "target": "app/user/u_456",
      "allowed": false
    },
    {
      "name": "ancestor-promotion-allows-exact-ancestor",
      "grants": ["sales/org/acme/account/a_789"],
      "target": "sales/org/acme",
      "writePolicy": {
        "descendants": true,
        "ancestorPromotion": "ancestors"
      },
      "allowed": true
    }
  ]
}
