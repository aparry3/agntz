{
  "name": "@agntz/provider-harness",
  "version": "0.1.5",
  "private": true,
  "description": "Multi-provider smoke harness for the agntz SDK — runs capability tests across (provider, model) combinations",
  "type": "module",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env.local --env-file-if-exists=../../.env.local src/index.ts",
    "lint": "biome check src --no-errors-on-unmatched",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agntz/core": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
