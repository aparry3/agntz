{
  "name": "@agntz/memrez",
  "version": "0.0.0",
  "description": "Durable tagged memory layer for agntz agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "agents"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests --no-errors-on-unmatched",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "agntz",
    "sqlite",
    "postgres"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparry3/agntz.git",
    "directory": "packages/memrez"
  },
  "homepage": "https://github.com/aparry3/agntz#readme",
  "author": "Aaron Bidworthy",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "pg": "^8.20.0",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@agntz/core": ">=1.2.1"
  },
  "devDependencies": {
    "@agntz/core": "workspace:*",
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
