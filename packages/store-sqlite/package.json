{
  "name": "@agent-runner/store-sqlite",
  "version": "0.1.1",
  "description": "SQLite store adapter for agent-runner — single-server production storage",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@agent-runner/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@agent-runner/core": ">=0.1.2"
  },
  "keywords": [
    "agent-runner",
    "sqlite",
    "store",
    "ai",
    "agents"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparry3/agent-runner.git",
    "directory": "packages/store-sqlite"
  },
  "homepage": "https://github.com/aparry3/agent-runner#readme",
  "author": "Aaron Bidworthy",
  "engines": {
    "node": ">=20.0.0"
  }
}
