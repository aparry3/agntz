{
  "name": "@agntz/manifest",
  "version": "0.1.0",
  "description": "YAML manifest engine for agntz: parser, template engine, state management, and pipeline execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparry3/agntz.git",
    "directory": "packages/manifest"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "peerDependencies": {
    "@agntz/core": "workspace:*"
  },
  "devDependencies": {
    "@agntz/core": "workspace:*",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
