{
  "name": "@agntz/store-postgres",
  "version": "1.0.0",
  "description": "PostgreSQL store adapter for agntz — multi-server production storage",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@agntz/core": "workspace:*",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@agntz/core": ">=1.0.0"
  },
  "keywords": [
    "agntz",
    "postgres",
    "postgresql",
    "store",
    "ai",
    "agents"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparry3/agntz.git",
    "directory": "packages/store-postgres"
  },
  "homepage": "https://github.com/aparry3/agntz#readme",
  "author": "Aaron Bidworthy",
  "engines": {
    "node": ">=22.0.0"
  }
}
