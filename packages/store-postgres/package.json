{
  "name": "@agent-runner/store-postgres",
  "version": "0.1.0",
  "description": "PostgreSQL store adapter for agent-runner \u2014 multi-server production storage",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "agent-runner": "workspace:*",
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "agent-runner": ">=0.1.0"
  },
  "keywords": [
    "agent-runner",
    "postgres",
    "postgresql",
    "store",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparryopenclaw/agent-runner.git",
    "directory": "packages/store-postgres"
  },
  "homepage": "https://github.com/aparryopenclaw/agent-runner#readme",
  "author": "Aaron Bidworthy"
}
