{
  "name": "@agntz/worker",
  "version": "0.1.0",
  "description": "Hono server for agent execution — runs YAML-defined agents via the manifest engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agntz-worker": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node --env-file=.env.local dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparry3/agntz.git",
    "directory": "packages/worker"
  },
  "dependencies": {
    "hono": "^4.12.0",
    "@hono/node-server": "^1.19.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.0",
    "dotenv": "^16.5.0",
    "@agntz/core": "workspace:*",
    "@agntz/manifest": "workspace:*",
    "@agntz/store-postgres": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
