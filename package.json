{
  "name": "agntz-monorepo",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "turbo build",
    "build:app": "pnpm --filter @agntz/app build",
    "build:site": "pnpm --filter @agntz/site build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "biome check --write packages/*/src packages/*/tests apps/provider-harness/src --no-errors-on-unmatched",
    "prepare": "node scripts/install-hooks.mjs",
    "dev": "turbo dev",
    "dev:app": "pnpm --filter @agntz/app dev",
    "dev:site": "pnpm --filter @agntz/site dev",
    "dev:worker": "pnpm --filter @agntz/worker dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.30.0",
    "lefthook": "^2.1.9",
    "turbo": "^2.9.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "hono": "4.12.23",
      "path-to-regexp": "8.4.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
