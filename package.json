{
  "name": "agntz-monorepo",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "turbo build",
    "build:app": "pnpm --filter @agntz/app build",
    "build:site": "pnpm --filter @agntz/site build",
    "test": "turbo test",
    "lint": "turbo lint",
    "dev": "turbo dev",
    "dev:app": "pnpm --filter @agntz/app dev",
    "dev:site": "pnpm --filter @agntz/site dev",
    "dev:worker": "pnpm --filter @agntz/worker dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.9.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
